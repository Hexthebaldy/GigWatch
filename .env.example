# OpenAI-compatible (Kimi K2)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=kimi-k2.5

# App
APP_TIMEZONE=Asia/Shanghai
DB_PATH=./data/gigwatch.sqlite
APP_PORT=9826

# Telegram 通知（可选，参考 docs/telegram-integration.md）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Feishu Bot（可选，参考 docs/feishu-bot-setup.md）
# 飞书应用凭据：用于换取 tenant_access_token 并发送消息
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# SDK 长连接模式下无需公网回调地址；确保本进程常驻即可
# 飞书开放平台 API 基础地址（一般不用改）
FEISHU_BASE_URL=https://open.feishu.cn

# 火山引擎融合信息搜索（web_search 工具）
WEB_SEARCH_KEY=
# 可选：APIKey 接入地址，默认 https://open.feedcoopapi.com/search_api/web_search
WEB_SEARCH_URL=https://open.feedcoopapi.com/search_api/web_search
# 可选：请求超时毫秒，默认 12000
WEB_SEARCH_TIMEOUT_MS=12000
